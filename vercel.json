{
  "version": 2,
  "functions": {
    "api/send-reminders.js": {
      "runtime": "nodejs20.x"
    },
    "api/save-reminder.js": {
      "runtime": "nodejs20.x"
    }
  },
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "0 3 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}